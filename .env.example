TRAIN_DATA_PATH=training/data/sample_training_data.csv
TRAIN_MODEL_DIR=training/models
TRAIN_MODEL_NAME=difficulty_model.pt
TRAIN_METRICS_NAME=training_metrics.json
TRAIN_EPOCHS=200
TRAIN_BATCH_SIZE=8
TRAIN_LEARNING_RATE=0.01
TRAIN_HIDDEN_DIM=16
TRAIN_DEVICE=cpu
TRAIN_SEED=42

# Edge camera capture over Tailscale / SSH
edge_host=100.x.y.z
edge_port=22
edge_user=your-edge-user
edge_pass=your-edge-password
edge_camera_device=/dev/video0
edge_gamma=1.8
edge_remote_agent_path=/tmp/store_agent/main.py
edge_remote_image_path=/tmp/store_agent/latest.jpg
edge_output_dir=/tmp/opencrane-edge-captures
edge_ssh_timeout=15
